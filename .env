# ── Testnet RPC endpoints ─────────────────────────────────────────────────────
# Transactions are TESTNET ONLY — do not add mainnet RPCs.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# ── Deployed contract ─────────────────────────────────────────────────────────
# Fill this in after running: npm run deploy:sepolia  or  npm run deploy:amoy
NEXT_PUBLIC_SOLVEMINT_ADDRESS=0xYourDeployedContractAddress

# ── Frontend public config ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs
# Get a free project ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=0419c3eb80917cb4f7eab38c7b076f61

# ── API (backend) ─────────────────────────────────────────────────────────────
WEB_ORIGIN=http://localhost:3000

# Pinata IPFS — required for real file pinning.
# Steps to get your JWT:
#   1. Go to https://app.pinata.cloud and sign up (free tier: 1 GB)
#   2. Click "API Keys" in the left sidebar
#   3. Click "New Key" → enable pinFileToIPFS + pinJSONToIPFS → Create
#   4. Copy the JWT (not the API key or secret) and paste it below
#   5. Test it: GET http://localhost:4000/api/ipfs/test  → should return {"ok":true}
# Without this, metadata is encoded locally as a base64 fallback (no true IPFS).
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..EkMc5UkJ3OFXmo2HnUO3zlP5uAoV1beTD_s9JwEjjz8

# ── Deployer wallet ───────────────────────────────────────────────────────────
# WARNING: Use a TESTNET-ONLY burner wallet. Never use your main wallet's key.
PRIVATE_KEY=your_testnet_deployer_private_key

# ── Block explorer API keys (optional, for contract verification) ─────────────
ETHERSCAN_API_KEY=optional_for_contract_verification
